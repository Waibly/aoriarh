# =============================================================================
# AORIA RH — Backend Environment Variables
# =============================================================================
# Copier ce fichier en .env et remplir les valeurs.
# NE JAMAIS committer le fichier .env dans git.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aoriarh
POSTGRES_USER=aoriarh
POSTGRES_PASSWORD=          # OBLIGATOIRE — mot de passe fort, min 20 caractères

# --- Qdrant ---
QDRANT_HOST=localhost
QDRANT_PORT=6333

# --- MinIO (stockage S3-compatible) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=           # OBLIGATOIRE — ne pas utiliser "minioadmin"
MINIO_SECRET_KEY=           # OBLIGATOIRE — ne pas utiliser "minioadmin"
MINIO_BUCKET=aoriarh-documents
MINIO_USE_SSL=false         # Passer à true en production avec TLS

# --- JWT / Sécurité ---
SECRET_KEY=                 # OBLIGATOIRE — générer avec : python -c "import secrets; print(secrets.token_urlsafe(64))"
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# --- Admin initial ---
SEED_ADMIN=false            # Mettre à true uniquement au premier déploiement ou en dev
ADMIN_EMAIL=
ADMIN_PASSWORD=             # OBLIGATOIRE si SEED_ADMIN=true — Min 16 caractères

# --- CORS ---
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# --- LLM / RAG ---
OPENAI_API_KEY=             # OBLIGATOIRE — sk-proj-...
LLM_MODEL=gpt-5-mini
VOYAGE_API_KEY=             # OBLIGATOIRE — pa-...

# --- Email (Brevo) ---
BREVO_API_KEY=              # OBLIGATOIRE — xkeysib-...

# --- Frontend URL ---
FRONTEND_URL=http://localhost:3000

# --- Judilibre API (PISTE — OAuth2) ---
JUDILIBRE_CLIENT_ID=               # OAuth Client ID depuis piste.gouv.fr
JUDILIBRE_CLIENT_SECRET=           # OAuth Client Secret depuis piste.gouv.fr
JUDILIBRE_BASE_URL=https://sandbox-api.piste.gouv.fr/cassation/judilibre/v1.0
JUDILIBRE_OAUTH_URL=https://sandbox-oauth.piste.gouv.fr/api/oauth/token
# Prod :
# JUDILIBRE_BASE_URL=https://api.piste.gouv.fr/cassation/judilibre/v1.0
# JUDILIBRE_OAUTH_URL=https://oauth.piste.gouv.fr/api/oauth/token

# --- Légifrance / KALI API (PISTE — même portail que Judilibre) ---
# Si vide, les credentials Judilibre ci-dessus seront utilisés.
# Il faut souscrire à l'API "Légifrance" sur piste.gouv.fr (même application).
LEGIFRANCE_CLIENT_ID=
LEGIFRANCE_CLIENT_SECRET=
LEGIFRANCE_BASE_URL=https://sandbox-api.piste.gouv.fr/dila/legifrance/lf-engine-app
LEGIFRANCE_OAUTH_URL=https://sandbox-oauth.piste.gouv.fr/api/oauth/token
# Prod :
# LEGIFRANCE_BASE_URL=https://api.piste.gouv.fr/dila/legifrance/lf-engine-app
# LEGIFRANCE_OAUTH_URL=https://oauth.piste.gouv.fr/api/oauth/token

# --- Redis (file d'attente ARQ) ---
REDIS_URL=redis://localhost:6379      # En Docker : redis://redis:6379

# --- Logging ---
LOG_FORMAT=text                       # "text" en dev (lisible), "json" en prod (structuré)

# --- Workers Gunicorn (Docker uniquement) ---
# Règle : (2 x vCPU disponibles pour le backend) + 1
# Voir TODO_PRODUCTION.md section 3 pour le dimensionnement
WORKERS=4
