# AORIA RH — Reverse proxy production
# Caddy obtient et renouvelle les certificats SSL automatiquement via Let's Encrypt.

# Site marketing (apex + www → apex)
aoriarh.fr, www.aoriarh.fr {
	encode zstd gzip
	@www host www.aoriarh.fr
	redir @www https://aoriarh.fr{uri} permanent
	reverse_proxy site:80
}

app.aoriarh.fr {
	header X-Robots-Tag "noindex, nofollow"
	reverse_proxy frontend:3000
}

api.aoriarh.fr {
	header X-Robots-Tag "noindex, nofollow"
	reverse_proxy backend:8000
}

monitoring.aoriarh.fr {
	reverse_proxy grafana:3000
}
